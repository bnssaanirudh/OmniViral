# ─────────────────────────────────────────────
#  OmniViral — Environment Configuration
# ─────────────────────────────────────────────

# App
APP_NAME=OmniViral
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=change-me-to-a-very-long-random-string-at-least-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://omni:omnipass@localhost:5432/omniviral
DATABASE_SYNC_URL=postgresql://omni:omnipass@localhost:5432/omniviral
POSTGRES_USER=omni
POSTGRES_PASSWORD=omnipass
POSTGRES_DB=omniviral
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT Auth
JWT_SECRET_KEY=another-very-long-secret-key-for-jwt-signing
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=omniviral-experiments
MLFLOW_S3_ENDPOINT_URL=

# AWS S3 Compatible Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=omniviral-assets
S3_ENDPOINT_URL=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=content_knowledge_base

# LLM Providers (optional — system works with mocks if not set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o

# Publishing APIs (mocks used if not set)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_API_KEY=

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# Gatekeeper
GATEKEEPER_SCORE_THRESHOLD=0.65
GATEKEEPER_MAX_CARAG_ITERATIONS=3

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads
INCOMING_VIDEOS_PATH=./incoming/videos
INCOMING_SCRIPTS_PATH=./incoming/scripts
INCOMING_METADATA_PATH=./incoming/metadata
